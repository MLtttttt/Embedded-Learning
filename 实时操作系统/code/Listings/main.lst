 142          void Timer0_Init(void)    //1毫秒@11.0592MHz
 143          {
 144   1        TMOD &= 0xF0;     //设置定时器模式
 145   1        TMOD |= 0x01;     //设置定时器模式
 146   1        TL0 = 0x66;       //设置定时初始值
 147   1        TH0 = 0xFC;       //设置定时初始值
 148   1        TF0 = 0;        //清除TF0标志
 149   1        TR0 = 1;        //定时器0开始计时
 150   1        ET0 = 1;        //使能定时器0中断
 151   1        EA = 1;
 152   1      }
 153          
 154          
 155          void Timer0_Isr(void) interrupt 1
 156          {
 157   1        unsigned char i; 
 158   1        
 159   1        TL0 = 0x66;       //设置定时初始值
 160   1        TH0 = 0xFC;       //设置定时初始值
 161   1        
 162   1        for(i = 0;i<MAX_TASKS;i++){
 163   2          if(tasks[i].status == TASK_SUSPENDED) tasks[i].delay_count++;//任务处于挂起状态则延时计数器+1
 164   2            if(tasks[i].delay_count>= tasks[i].delay_time){//达到需要的延时时间
 165   3            tasks[i].status =TASK_RUNNING;//睡眠结束，设为运行状态
 166   3            tasks[i].delay_count = 0;//清0复位
 167   3        }
 168   2        }
 169   1      }
