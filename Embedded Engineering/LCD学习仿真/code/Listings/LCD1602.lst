  10          #define LCD_DataPort P2
  11          
  12          // 短延时函数（12MHz 晶振）
  13          void LCD_Delay(void)
  14          {
  15   1          unsigned char data i, j;
  16   1          i = 2;
  17   1          j = 239;
  18   1          do
  19   1          {
  20   2              while (--j);
  21   2          } while (--i);
  22   1      }
  23          
  24          // 写命令
  25          void LCD_WriteCommand(unsigned char Command)
  26          {
  27   1          LCD_RS = 0;               // 命令模式
  28   1          LCD_RW = 0;               // 写模式
  29   1          LCD_DataPort = Command;   // 放置命令
  30   1          LCD_E = 1;                // 产生一个高脉冲
  31   1          LCD_Delay();
  32   1          LCD_E = 0;
  33   1          LCD_Delay();
  34   1      }
  35          
