   5          /**
   6           * 串口初始化函数
   7           */
   8          void Uart_Init(void) { //9600bps @11.0592MHz
   9   1          SCON = 0x50;          // 设置串口控制寄存器：模式1（8位UART），允许接收（REN=1）
  10   1          TMOD &= 0x0F;         // 清除定时器1的模式位（保留定时器0的设置）
  11   1          TMOD |= 0x20;         // 设置定时器1为模式2（8位自动重装）
  12   1          TH1 = 0xFD;           // 波特率重装值高位
  13   1          TL1 = 0xFD;           // 定时器1初值，与TH1相同（模式2下自动重装）
  14   1          TR1 = 1;              // 启动定时器1
  15   1      }
  16          
  17          /**
  18           * 串口发送单字节函数（查询方式）
  19           * @param dat 待发送的字节数据
  20           */
  21          void Uart_Send(unsigned char dat) {
  22   1          SBUF = dat;  
  23   1          while (!TI); 
  24   1          TI = 0; 
  25   1      }
  26          
  27          /**
  28           * 串口发送当前时间函数
  29           */
  30          void Uart_result(void) {
  31   1          Uart_Send(buf[0] + '0');   // 分钟十位
  32   1          Uart_Send(buf[1] + '0');   // 分钟个位
  33   1          Uart_Send(':');            // 分隔符
  34   1          Uart_Send(buf[3] + '0');   // 秒十位
  35   1          Uart_Send(buf[4] + '0');   // 秒个位
  36   1          Uart_Send('.');            // 小数点
  37   1          Uart_Send(buf[6] + '0');   // 毫秒十位（实际为厘秒十位）
  38   1          Uart_Send(buf[7] + '0');   // 毫秒个位（厘秒个位）
  39   1          Uart_Send('\r');           // 回车
  40   1          Uart_Send('\n');           // 换行
  41   1      }
  42          
  43          /**
  44           * 串口发送字符串函数
  45           * @param str 以'\0'结尾的字符串指针
  46           */
  47          void Uart_assess(char *str) {
  48   1          while (*str) {             // 遍历字符串直到结束符
  49   2              Uart_Send(*str++);     // 逐个发送字符，并移动指针
  50   2          }
  51   1      }
  52          
  53          /**
  54           * 发送评级函数
C51 COMPILER V9.60.7.0   UART                                                              03/02/2026 17:24:55 PAGE 2   

  55           * 根据LED亮灯数量（count）发送对应的等级字符串
  56           * @param count LED亮灯个数（0~3）
  57           */
  58          void Send_grade(unsigned char count) {
  59   1          if (count == 3)
  60   1              Uart_assess("Excellent!");   // 3灯亮：Excellent!
  61   1          else if (count == 2)
  62   1              Uart_assess("Good!");        // 2灯亮：Good!
  63   1          else if (count == 1)
  64   1              Uart_assess("Pass");         // 1灯亮：Pass
  65   1          else
  66   1              Uart_assess("Unqualified");  // 其他情况（0灯）：Unqualified
  67   1      }


