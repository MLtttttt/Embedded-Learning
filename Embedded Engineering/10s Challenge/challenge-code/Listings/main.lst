 130           */
 131          void Timer0_isr(void) interrupt 1 {
 132   1          TH0 = 0xFC;       // 11.0592MHz 1ms
 133   1          TL0 = 0x66;
 134   1      
 135   1          // 数码管动态扫描（每次中断显示一位）
