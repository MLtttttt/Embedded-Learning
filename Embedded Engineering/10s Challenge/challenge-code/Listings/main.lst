  74          /**
  75           * 按键扫描函数（阻塞式）
  76           * 检测启动/暂停键和清零键，带消抖和等待释放
  77           */
  78          void Key_Scan(void) {
  79   1          // 启动/暂停键处理
  80   1          if( Key_start == 0) {     
  81   2              Delay10ms();                  
  82   2              if(Key_start == 0) {             
  83   3                  flag = !flag;                 
  84   3                  if(flag == 0) {               
  85   4                      Judge_LED();// 成绩判断，点亮LED
  86   4                      Uart_result();// 串口发送当前时间
  87   4                      Send_grade(LED_count);// 串口发送评级
  88   4                      Uart_Send('\r');// 发送回车
  89   4                      Uart_Send('\n');// 发送换行
  90   4                  }
  91   3                  while(Key_start == 0);
  92   3              }
  93   2          }
  94   1          
  95   1          // 清零键处理
  96   1          else if(Key_clear == 0) { 
  97   2              Delay10ms();
  98   2              if(Key_clear == 0) {
  99   3                  flag = 0; 
 100   3                  min = 0, sec = 0, msec = 0;     // 计时归零
 101   3                  LED1 = 0, LED2 = 0, LED3 = 0;  
 102   3                  while(Key_clear == 0);
 103   3              }
 104   2          }
 105   1      }
