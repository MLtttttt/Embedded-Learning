  54           */
C51 COMPILER V9.60.7.0   MAIN                                                              03/02/2026 17:24:55 PAGE 2   

  55          void Judge_LED(void) {
  56   1          u32 total_time = (u32)min * 60 * 1000 + (u32)sec * 1000 + msec; // 总毫秒数
  57   1          u32 t = total_time / 10; // 转换为厘秒（0.01秒为单位）提高可读性
  58   1      
  59   1          if(t >= 950 && t <= 1050) { // 9.50~10.50秒
  60   2              LED1 = 1, LED2 = 0, LED3 = 0;  
  61   2              LED_count = 1; // 记录亮灯数
  62   2          }
  63   1          else if(t >= 850 && t < 950) {// 8.50~9.50秒
  64   2              LED1 = 1, LED2 = 1, LED3 = 0; 
  65   2              LED_count = 2;
  66   2          }
  67   1          else if(t>=750 && t < 850) {// 7.50~8.50秒
  68   2              LED1 = 1, LED2 = 1, LED3 = 1;
  69   2              LED_count = 3;
  70   2          }
  71   1      }
  72          
